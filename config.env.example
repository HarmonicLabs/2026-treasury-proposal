# Treasury Proposal Configuration
# Copy to config.env and fill in values. NEVER commit config.env.

# Governance action deposit (100k ADA in lovelace)
GOVERNANCE_ACTION_DEPOSIT=100000000000

# Key files
DEPOSIT_RETURN_STAKE_VKEY=keys/deposit-return-stake.vkey
# Receiving credential: use VKEY for key-based, SCRIPT_FILE for contract-based
# For mainnet with SundaeSwap treasury contract, use RECEIVING_STAKE_SCRIPT_FILE
RECEIVING_STAKE_VKEY=keys/receiving-stake.vkey
RECEIVING_STAKE_SCRIPT_FILE=

# Signing: set HW_SIGNING_FILE for hardware wallets, or SKEY for file-based keys.
# If both are set, hardware wallet takes priority.
PAYMENT_HW_SIGNING_FILE=
DEPOSIT_RETURN_STAKE_HW_SIGNING_FILE=
PAYMENT_SKEY=keys/payment.skey

# Proposal signing key: a dedicated software key used ONLY for governance transactions.
# Ledger hardware wallets cannot sign transactions with proposal_procedures (CIP-0021).
# Before submitting, `fund-proposal.sh` transfers the required ADA from the HW wallet
# to this key's address. The proposal tx spends from this address and returns change
# to PAYMENT_ADDRESS (HW wallet).
PROPOSAL_SKEY=
PROPOSAL_VKEY=

# Metadata file (default: metadata/proposal-metadata.json)
# For testnet testing, use metadata/test-metadata.json
METADATA_FILE=

# Metadata anchor URL
ANCHOR_URL=

# Transfer amount (in lovelace)
TRANSFER_AMOUNT=

# Payment address for change
PAYMENT_ADDRESS=

# Pinata API key for IPFS uploads
PINATA_JWT=

# IPFS gateway for anchor data verification
IPFS_GATEWAY_URI=https://gateway.pinata.cloud/ipfs/

# Node socket
CARDANO_NODE_SOCKET_PATH=

# Reference UTxOs holding scripts on-chain (TxId#TxIx format, e.g. abc123...#0)
# Set these after deploying reference scripts to a UTxO. When set, transactions
# use --*-tx-in-reference (cheaper, smaller tx) instead of including scripts inline.
# If left empty, scripts fall back to inline inclusion with a warning.
#
# TREASURY_SCRIPT_REF_UTXO: UTxO holding the treasury contract (treasury-contract.plutus).
#   Used by: register-receiving-stake.sh, delegate-always-abstain.sh
TREASURY_SCRIPT_REF_UTXO=
# GUARDRAILS_SCRIPT_REF_UTXO: UTxO holding the guardrails script (guardrails.plutus).
#   Used by: build-tx.sh (proposal script witness)
GUARDRAILS_SCRIPT_REF_UTXO=

# Contract time parameters (any value accepted by JavaScript's `new Date()`)
# Examples: "2030-01-01", "2030-01-01T00:00:00Z", "January 1, 2030"
# Converted to POSIX milliseconds via Date.valueOf() during build.
TREASURY_EXPIRATION=
PAYOUT_UPPERBOUND=
VENDOR_EXPIRATION=

# Oversight board pubkey hashes (for treasury contract deployment)
OVERSIGHT_SANTIAGO_CARMUEGA=946a76ec4564f793d643cb13ff900f2ec578bcd521addab275af5ebb
OVERSIGHT_CHRIS_GIANELLONI=058a5ab0c66647dcce82d7244f80bfea41ba76c7c9ccaf86a41b00fe
OVERSIGHT_LUCAS_ROSA=ccc4a58ebc9aa058cd0dee6f84e4de39e23574a054e405b0ca467a88