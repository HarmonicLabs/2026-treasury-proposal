# Per-proposal configuration template.
# Each proposal under proposals/<name>/ has its own config.env with these
# values. Shared values (keys, oversight, IPFS, node socket, contract dates)
# live in ../../config.shared.env (see config.shared.env.example at repo root).

# Treasury withdrawal requested amount (in lovelace).
# 5 FTE × $225,000 × 1.15 contingency ÷ $0.25/ADA = 5,175,000 ADA
TRANSFER_AMOUNT=5175000000000

# Metadata anchor URL — set after `make upload-ipfs PROPOSAL=<name>`.
ANCHOR_URL=
